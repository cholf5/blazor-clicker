@* Grid of upgrade buttons — only visible upgrades (unlocked, not owned)
   appear, sorted by cost. Grayed-out when unaffordable. *@

<section class="upgrade-store">
    <header class="upgrade-header">
        <h2>Upgrades</h2>
        <span class="upgrade-count">@_available.Count available</span>
    </header>

    @if (_available.Count == 0)
    {
        <div class="upgrade-empty">Keep clicking and buying buildings to unlock upgrades.</div>
    }
    else
    {
        <div class="upgrade-grid">
            @foreach (var up in _available)
            {
                var affordable = State.Cookies >= up.Cost;
                <button class="upgrade-tile @(affordable ? "" : "locked")"
                        disabled="@(!affordable)"
                        @onclick="() => State.BuyUpgrade(up.Id)"
                        title="@up.Name — @up.Description (@NumberFormat.Format(up.Cost) cookies)">
                    <span class="upgrade-icon">@up.Icon</span>
                    <span class="upgrade-cost">@NumberFormat.Format(up.Cost)</span>
                </button>
            }
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public GameState State { get; set; } = default!;

    private List<UpgradeDefinition> _available = new();

    protected override void OnParametersSet()
    {
        _available = State.AvailableUpgrades().ToList();
    }
}
