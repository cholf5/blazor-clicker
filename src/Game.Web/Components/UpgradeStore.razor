@* Grid of upgrade buttons — only visible upgrades (unlocked, not owned)
   appear, sorted by cost. Grayed-out when unaffordable. *@

@inject TooltipService Tooltip
@inject ILocalizer Loc

<section class="upgrade-store">
    <header class="upgrade-header">
        <h2>@Loc["ui.upgrades.title"]</h2>
        <span class="upgrade-count">@Loc.Format("ui.upgrades.count", _available.Count)</span>
    </header>

    @if (_available.Count == 0)
    {
        <div class="upgrade-empty">@Loc["ui.upgrades.empty"]</div>
    }
    else
    {
        <div class="upgrade-grid">
            @foreach (var up in _available)
            {
                var affordable = State.Cookies >= up.Cost;
                <button class="upgrade-tile @(affordable ? "" : "locked")"
                        @ref="_tiles[up.Id]"
                        disabled="@(!affordable)"
                        @onclick="() => Buy(up.Id)"
                        @onmouseover="() => Tooltip.Show(() => BuildTooltip(up), _tiles[up.Id])"
                        @onmouseout="Tooltip.Hide">
                    <span class="upgrade-icon">@up.Icon</span>
                    <span class="upgrade-cost">@NumberFormat.Format(up.Cost)</span>
                </button>
            }
        </div>
    }
</section>

@code {
    [Parameter, EditorRequired] public GameState State { get; set; } = default!;
    [Parameter] public EventCallback OnPurchased { get; set; }

    private List<UpgradeDefinition> _available = new();

    // Per-tile element refs so the tooltip can anchor beside the hovered tile.
    private readonly Dictionary<string, ElementReference> _tiles = new();

    protected override void OnParametersSet()
    {
        _available = State.AvailableUpgrades().ToList();
    }

    private async Task Buy(string id)
    {
        if (State.BuyUpgrade(id))
        {
            Tooltip.Hide();
            await OnPurchased.InvokeAsync();
        }
    }

    private RenderFragment BuildTooltip(UpgradeDefinition up)
    {
        var rows = new List<(string, string)>
        {
            (Loc["ui.tooltip.effect"], EffectText(up)),
        };

        return @<TooltipCard Icon="@up.Icon"
                             Title="@up.DisplayName(Loc)"
                             Tag="@Loc[$"ui.upgrade_category.{up.Category.ToString().ToLowerInvariant()}"]"
                             CssClass="upgrade"
                             Cost="@NumberFormat.Format(up.Cost)"
                             Rows="rows"
                             Flavor="@up.DisplayDescription(Loc)" />;
    }

    private string EffectText(UpgradeDefinition up) => up.EffectKind switch
    {
        UpgradeEffectKind.BuildingMultiplier =>
            Loc.Format("ui.effect.building_multiplier", up.EffectValue.ToString("0.##"),
                up.TargetBuilding is { } b ? Buildings.Get(b).DisplayName(Loc) : Loc["ui.effect.building_fallback"]),
        UpgradeEffectKind.ClickMultiplier => Loc.Format("ui.effect.click_multiplier", up.EffectValue.ToString("0.##")),
        UpgradeEffectKind.GlobalCpsMultiplier => Loc.Format("ui.effect.global_multiplier", up.EffectValue.ToString("0.##")),
        // Kitten effect is milk-dependent: show the live effective factor
        // (recomputed each render via the tooltip builder) plus the per-milk rate.
        UpgradeEffectKind.KittenMilkMultiplier => Loc.Format("ui.effect.kitten",
            (1 + State.MilkFactor() * up.EffectValue).ToString("0.##"),
            (up.EffectValue * 100).ToString("0.##")),
        UpgradeEffectKind.CursorPerNonCursorBuilding =>
            Loc.Format("ui.effect.cursor_synergy", NumberFormat.Format(up.EffectValue)),
        _ => up.DisplayDescription(Loc),
    };
}
