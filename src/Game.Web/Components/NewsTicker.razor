@* Scrolling headline strip that shows a mixture of:
   * event lines emitted by GameState (achievements, golden cookies, sugar
     lumps, ascensions) via DrainNewsMessages
   * ambient flavor pulled from NewsFlavor when the queue is idle
   * a progression-linked headline that changes as the player crosses
     lifetime-baked thresholds. *@

@implements IDisposable
@inject ILocalizer Loc

<div class="news-ticker" role="status" aria-label="News ticker">
    <span class="news-icon">📰</span>
    <div class="news-track" title="@_current">
        <span class="news-item" @key="_currentKey">@_current</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public GameState State { get; set; } = default!;

    private readonly Random _rng = new();
    private readonly Queue<NewsMessage> _pending = new();
    private DateTime _nextRotate = DateTime.UtcNow;
    private string _current = "";
    private int _currentKey;

    protected override void OnInitialized()
    {
        // Seed with the welcome line in the current language.
        _current = Loc["news.progress.welcome"];
    }

    /// <summary>
    /// Called by the parent every frame so we can drain the state queue and
    /// rotate the currently displayed headline on a fixed cadence.
    /// </summary>
    public void Pump()
    {
        // Absorb any freshly emitted event messages (translation key + args).
        foreach (var msg in State.DrainNewsMessages())
            _pending.Enqueue(msg);

        if (DateTime.UtcNow < _nextRotate) return;

        string next;
        if (_pending.TryDequeue(out var queued))
        {
            next = NewsFlavor.Resolve(queued, Loc);
            _nextRotate = DateTime.UtcNow.AddSeconds(5);
        }
        else
        {
            // Alternate between ambient flavor and the current progression tier.
            var key = _rng.Next(3) == 0
                ? NewsFlavor.PickProgressKey(State) ?? NewsFlavor.PickIdleKey(_rng)
                : NewsFlavor.PickIdleKey(_rng);
            next = Loc[key];
            _nextRotate = DateTime.UtcNow.AddSeconds(8);
        }

        if (next != _current)
        {
            _current = next;
            _currentKey++;
        }
    }

    public void Dispose() { }
}
