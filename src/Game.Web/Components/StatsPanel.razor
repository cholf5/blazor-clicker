@* Top-of-column stats panel. Reads live from GameState — parent controls
   re-render frequency by subscribing to the game loop. *@

@inject ILocalizer Loc

<div class="stats">
    <div class="stats-bank">
        <div class="stats-bank-count">@NumberFormat.FormatStable(State.Cookies)</div>
        <div class="stats-bank-label">@Loc["ui.stats.cookies_unit"]</div>
    </div>
    <div class="stats-cps">
        @Loc["ui.stats.per_second"] <strong>@NumberFormat.FormatRate(State.CurrentCps())</strong>
    </div>
    <div class="stats-meta">
        <span title="@Loc["ui.stats.baked_title"]">@Loc.Format("ui.stats.baked", NumberFormat.Format(State.TotalCookiesBaked))</span>
        <span title="@Loc["ui.stats.clicks_title"]">@Loc.Format("ui.stats.clicks", NumberFormat.Format(State.HandmadeClicks))</span>
        <span title="@Loc["ui.stats.ach_title"]">🏆 @State.UnlockedAchievements.Count / @Achievements.All.Count</span>
    </div>
    @if (State.Buffs.Count > 0)
    {
        <div class="stats-buffs">
            @foreach (var buff in State.Buffs)
            {
                var remaining = Math.Max(0, buff.ExpiresAt - State.GameTime);
                <span class="buff buff-@buff.Effect.ToString().ToLowerInvariant()">
                    @BuffLabel(buff.Effect) — @remaining.ToString("0")s
                </span>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public GameState State { get; set; } = default!;

    private string BuffLabel(GoldenCookieEffect e) => e switch
    {
        GoldenCookieEffect.Frenzy => Loc["ui.buff.frenzy"],
        GoldenCookieEffect.ClickFrenzy => Loc["ui.buff.click_frenzy"],
        _ => e.ToString()
    };
}
