@* Ascend / prestige panel. Hidden entirely until the player has any hope
   of gaining a level. Shows preview of gain and confirmation dialog. *@

@inject AudioService Audio
@inject ILocalizer Loc

@if (Visible)
{
    <section class="ascend-panel">
        <header class="ascend-header">
            <h3>@Loc["ui.ascend.title"]</h3>
            @if (State.PrestigeLevel > 0)
            {
                <span class="ascend-current" title="@Loc["ui.ascend.current_title"]">
                    ✨ @State.PrestigeLevel · +@(_prestigePercent.ToString("0.#"))%
                </span>
            }
        </header>

        @if (_confirming)
        {
            <div class="ascend-confirm">
                <p>@Loc["ui.ascend.confirm_body"]</p>
                <p>@Loc.Format(_available == 1 ? "ui.ascend.confirm_gain_one" : "ui.ascend.confirm_gain", _available)</p>
                <div class="ascend-actions">
                    <button class="ascend-btn danger" @onclick="ConfirmAscend">@Loc["ui.ascend.button"]</button>
                    <button class="ascend-btn" @onclick="() => _confirming = false">@Loc["ui.ascend.cancel"]</button>
                </div>
            </div>
        }
        else
        {
            @if (_available > 0)
            {
                <p class="ascend-blurb">
                    @Loc.Format(_available == 1 ? "ui.ascend.blurb_one" : "ui.ascend.blurb",
                        _available, (ProgressionConfig.PrestigeCpsBonus * 100).ToString("0.#"))
                </p>
                <button class="ascend-btn" @onclick="() => _confirming = true">🌈 @Loc["ui.ascend.button"]</button>
            }
            else
            {
                <p class="ascend-blurb">
                    @Loc.Format("ui.ascend.locked",
                        NumberFormat.Format(ProgressionConfig.MinCookiesToAscend),
                        NumberFormat.Format(State.TotalCookiesBaked))
                </p>
            }
        }
    </section>
}

@code {
    [Parameter, EditorRequired] public GameState State { get; set; } = default!;
    [Parameter] public EventCallback OnAscended { get; set; }

    private bool _confirming;
    private int _available;
    private double _prestigePercent;

    protected override void OnParametersSet()
    {
        _available = State.PrestigeAvailableFromAscend();
        _prestigePercent = State.PrestigeLevel * ProgressionConfig.PrestigeCpsBonus * 100;
    }

    // Show once the player is within 10% of the threshold, so the panel
    // gives a heads-up before they can actually push the button.
    private bool Visible =>
        State.AscensionCount > 0
        || State.PrestigeLevel > 0
        || State.TotalCookiesBaked >= ProgressionConfig.MinCookiesToAscend * 0.1;

    private async Task ConfirmAscend()
    {
        if (State.Ascend())
        {
            Audio.PlayAscend();
            _confirming = false;
            await OnAscended.InvokeAsync();
        }
    }
}
