@* Big central cookie the player clicks. Emits OnClick for each click and
   drives a brief transform:scale animation via a tick counter used as a
   render key. Floating "+N" numbers are spawned by the parent. *@

@inject ILocalizer Loc

<button class="big-cookie @(_bounce ? "bounce" : "")"
        @onclick="HandleClick"
        aria-label="@Loc["ui.cookie.aria"]"
        title="@Loc["ui.cookie.title"]">
    @* Hand-drawn (AI-redrawn, no original art reused — see NOTICE.md) cookie
       image. A 500×500 transparent PNG whose visible pixels are centred on the
       canvas, so its geometric centre equals its visual centre — unlike the
       emoji it replaced, which sat off-centre in its text box and threw the
       decorative cursor ring's alignment off. draggable=false suppresses the
       browser's ghost-drag image. *@
    <img class="big-cookie-img" src="img/big-cookie.png" alt="@Loc["ui.cookie.aria"]" draggable="false" />
</button>

@code {
    [Parameter, EditorRequired] public EventCallback<MouseEventArgs> OnClick { get; set; }

    private bool _bounce;

    private async Task HandleClick(MouseEventArgs e)
    {
        _bounce = true;
        await OnClick.InvokeAsync(e);
        // Reset bounce class shortly after so subsequent clicks retrigger the animation.
        _ = InvokeAsync(async () =>
        {
            await Task.Delay(80);
            _bounce = false;
            StateHasChanged();
        });
    }
}
