@* One row in the building list. Handles buy / bulk-buy / affordability
   styling. Emits OnBuy for the parent to invoke on GameState. *@

@inject TooltipService Tooltip
@inject ILocalizer Loc

@if (Locked)
{
    var unlockThreshold = State.BuildingUnlockThreshold(Definition.Id);

    <button class="building-row locked-preview"
            @ref="_row"
            @onmouseover="ShowLockedTooltip"
            @onmouseout="Tooltip.Hide"
            disabled>
        <span class="building-icon">🔒</span>
        <span class="building-body">
            <span class="building-name">@Loc["ui.building.locked_name"]</span>
            <span class="building-cost">@Loc.Format("ui.building.unlocks_at", NumberFormat.Format(unlockThreshold))</span>
        </span>
    </button>
}
else
{
    var owned = State.BuildingCounts.GetValueOrDefault(Definition.Id);
    var unitCost = State.NextBuildingCost(Definition.Id);
    var bulkCost = BulkAmount > 1 ? State.BulkBuildingCost(Definition.Id, BulkAmount) : unitCost;
    var canAffordBulk = State.Cookies >= bulkCost;
    var unitCps = State.GetBuildingUnitCps(Definition.Id);
    var totalCps = unitCps * owned;

    <button class="building-row @(canAffordBulk ? "" : "locked")"
            @ref="_row"
            @onclick="() => OnBuy.InvokeAsync(BulkAmount)"
            @onmouseover="ShowTooltip"
            @onmouseout="Tooltip.Hide"
            disabled="@(!canAffordBulk)">
        <span class="building-icon">@Definition.Icon</span>
        <span class="building-body">
            <span class="building-name">@Definition.DisplayName(Loc)</span>
            <span class="building-cost">
                @NumberFormat.Format(bulkCost)
                @if (BulkAmount > 1) { <span class="bulk-tag">× @BulkAmount</span> }
            </span>
            <span class="building-info">
                @if (owned > 0)
                {
                    <span>@Loc.Format("ui.building.owns", owned)</span>
                    <span>@Loc.Format("ui.building.cps_total", NumberFormat.Format(totalCps))</span>
                }
                else
                {
                    <span>@Loc.Format("ui.building.cps_each", NumberFormat.Format(unitCps))</span>
                }
            </span>
        </span>
        <span class="building-count">@owned</span>
    </button>
}

@code {
    [Parameter, EditorRequired] public GameState State { get; set; } = default!;
    [Parameter, EditorRequired] public BuildingDefinition Definition { get; set; } = default!;
    [Parameter] public int BulkAmount { get; set; } = 1;
    [Parameter] public bool Locked { get; set; }
    [Parameter] public EventCallback<int> OnBuy { get; set; }

    private ElementReference _row;

    private void ShowTooltip() => Tooltip.Show(BuildTooltip(), _row);

    private void ShowLockedTooltip() => Tooltip.Show(BuildLockedTooltip(), _row);

    private RenderFragment BuildLockedTooltip() =>
        @<TooltipCard Icon="🔒"
                      Title="@Loc["ui.building.locked_name"]"
                      CssClass="building"
                      Flavor="@Loc["ui.building.locked_flavor"]" />;

    private RenderFragment BuildTooltip()
    {
        var owned = State.BuildingCounts.GetValueOrDefault(Definition.Id);
        var unitCost = State.NextBuildingCost(Definition.Id);
        var unitCps = State.GetBuildingUnitCps(Definition.Id);
        var totalCps = unitCps * owned;

        var rows = new List<(string, string)>
        {
            (Loc["ui.building.owned"], owned.ToString()),
            (Loc["ui.building.each_produces"], Loc.Format("ui.unit.cps", NumberFormat.Format(unitCps))),
        };

        if (owned > 0)
        {
            rows.Add((Loc["ui.building.total_from"], Loc.Format("ui.unit.cps", NumberFormat.Format(totalCps))));
            var share = State.BuildingCpsShare(Definition.Id);
            if (share > 0)
            {
                rows.Add((Loc["ui.building.share"], $"{share * 100:0.#}%"));
            }
        }

        // How long one copy takes to pay for itself from its own output.
        if (unitCps > 0)
        {
            rows.Add((Loc["ui.building.pays_for"], FormatSeconds(unitCost / unitCps)));
        }

        var costValue = NumberFormat.Format(BulkAmount > 1 ? State.BulkBuildingCost(Definition.Id, BulkAmount) : unitCost)
            + (BulkAmount > 1 ? $" ×{BulkAmount}" : "");

        return @<TooltipCard Icon="@Definition.Icon"
                             Title="@Definition.DisplayName(Loc)"
                             CssClass="building"
                             Cost="@costValue"
                             Rows="rows"
                             Flavor="@Definition.DisplayFlavor(Loc)" />;
    }

    private static string FormatSeconds(double seconds)
    {
        if (!double.IsFinite(seconds)) return "—";
        if (seconds < 60) return $"{seconds:0.#} s";
        if (seconds < 3600) return $"{seconds / 60:0.#} min";
        if (seconds < 86400) return $"{seconds / 3600:0.#} h";
        return $"{seconds / 86400:0.#} d";
    }
}
