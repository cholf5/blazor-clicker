@* Grid of every achievement in the game, grouped into filterable tabs.
   Locked ones show as silhouettes. *@

@inject TooltipService Tooltip
@inject ILocalizer Loc

<section class="achievements">
    <header class="achievements-header">
        <h2>@Loc["ui.achievements.title"]</h2>
        <span class="achievements-count">@State.UnlockedAchievements.Count / @Achievements.All.Count</span>
    </header>

    <nav class="achievement-tabs">
        <button class="achievement-tab @(_selected is null ? "active" : "")"
                @onclick="() => Select(null)">
            <span class="tab-icon">🏆</span>
            <span class="tab-count">@State.UnlockedAchievements.Count/@Achievements.All.Count</span>
        </button>
        @foreach (var cat in AchievementCategories.All)
        {
            var c = cat;
            var total = CountIn(c);
            var unlocked = CountUnlockedIn(c);
            <button class="achievement-tab @(_selected?.Key == c.Key ? "active" : "") @(unlocked == total ? "complete" : "")"
                    title="@c.DisplayLabel(Loc)"
                    @onclick="() => Select(c)">
                <span class="tab-icon">@c.Icon</span>
                <span class="tab-count">@unlocked/@total</span>
            </button>
        }
    </nav>

    <div class="achievement-grid">
        @foreach (var ach in VisibleAchievements)
        {
            var unlocked = State.UnlockedAchievements.Contains(ach.Id);
            <div class="achievement-tile @(unlocked ? "unlocked" : "locked")"
                 @key="ach.Id"
                 @ref="_tiles[ach.Id]"
                 @onmouseover="() => ShowTooltip(ach, unlocked)"
                 @onmouseout="Tooltip.Hide">
                <span class="achievement-icon">@(unlocked ? ach.Icon : "🔒")</span>
            </div>
        }
    </div>
</section>

@code {
    [Parameter, EditorRequired] public GameState State { get; set; } = default!;

    // Per-tile element refs so the tooltip can anchor beside the hovered tile.
    private readonly Dictionary<string, ElementReference> _tiles = new();

    // Null = "All" tab; otherwise the currently selected category.
    private AchievementCategory? _selected;

    private IEnumerable<AchievementDefinition> VisibleAchievements =>
        _selected is null
            ? Achievements.All
            : Achievements.All.Where(a => _selected.Matches(a.Id));

    private void Select(AchievementCategory? category)
    {
        _selected = category;

        // The visible set swaps with the tab, so drop element refs for
        // achievements that are no longer shown. Left in place they'd be stale
        // (detached DOM) — harmless today because ShowTooltip only reads refs
        // for visible tiles, but a future reorder/filter would let a stale ref
        // anchor the tooltip to nothing and send it to the corner. Keeping the
        // dictionary tight matches UpgradeStore and the anchor contract.
        var live = VisibleAchievements.Select(a => a.Id).ToHashSet();
        foreach (var id in _tiles.Keys.Where(k => !live.Contains(k)).ToList())
        {
            _tiles.Remove(id);
        }
    }

    private int CountIn(AchievementCategory category) =>
        Achievements.All.Count(a => category.Matches(a.Id));

    private int CountUnlockedIn(AchievementCategory category) =>
        Achievements.All.Count(a => category.Matches(a.Id) && State.UnlockedAchievements.Contains(a.Id));

    // Anchor the tooltip only once this tile's element ref is captured. The
    // visible set swaps when a category tab is selected, so a mouseover can
    // fire in the window before `@ref` has (re)populated `_tiles` for this id;
    // indexing the dictionary directly there throws KeyNotFoundException.
    private void ShowTooltip(AchievementDefinition ach, bool unlocked)
    {
        if (_tiles.TryGetValue(ach.Id, out var anchor))
        {
            Tooltip.Show(() => BuildTooltip(ach, unlocked), anchor);
        }
    }

    private RenderFragment BuildTooltip(AchievementDefinition ach, bool unlocked)
    {
        if (!unlocked)
        {
            return @<TooltipCard Icon="🔒" Title="@Loc["ui.achievements.locked_title"]" CssClass="locked"
                                 Flavor="@Loc["ui.achievements.locked_flavor"]" />;
        }

        return @<TooltipCard Icon="@ach.Icon" Title="@ach.DisplayName(Loc)" Tag="@Loc["ui.achievements.unlocked_tag"]"
                             CssClass="achievement" Flavor="@ach.DisplayDescription(Loc)" />;
    }
}
