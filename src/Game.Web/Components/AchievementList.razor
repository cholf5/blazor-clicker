@* Grid of every achievement in the game. Locked ones show as silhouettes. *@

@inject TooltipService Tooltip

<section class="achievements">
    <header class="achievements-header">
        <h2>Achievements</h2>
        <span class="achievements-count">@State.UnlockedAchievements.Count / @Achievements.All.Count</span>
    </header>

    <div class="achievement-grid">
        @foreach (var ach in Achievements.All)
        {
            var unlocked = State.UnlockedAchievements.Contains(ach.Id);
            <div class="achievement-tile @(unlocked ? "unlocked" : "locked")"
                 @ref="_tiles[ach.Id]"
                 @onmouseover="() => Tooltip.Show(BuildTooltip(ach, unlocked), _tiles[ach.Id])"
                 @onmouseout="Tooltip.Hide">
                <span class="achievement-icon">@(unlocked ? ach.Icon : "🔒")</span>
            </div>
        }
    </div>
</section>

@code {
    [Parameter, EditorRequired] public GameState State { get; set; } = default!;

    // Per-tile element refs so the tooltip can anchor beside the hovered tile.
    private readonly Dictionary<string, ElementReference> _tiles = new();

    private RenderFragment BuildTooltip(AchievementDefinition ach, bool unlocked)
    {
        if (!unlocked)
        {
            return @<TooltipCard Icon="🔒" Title="???" CssClass="locked"
                                 Flavor="This achievement is still locked." />;
        }

        return @<TooltipCard Icon="@ach.Icon" Title="@ach.Name" Tag="Unlocked"
                             CssClass="achievement" Flavor="@ach.Description" />;
    }
}
