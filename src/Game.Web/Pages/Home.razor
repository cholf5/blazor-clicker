@page "/"
@inject SaveCoordinator Save
@inject GameLoop Loop
@inject AudioService Audio
@inject ILocalizer Loc
@inject LanguageService Lang
@inject UpdateChecker Updater
@implements IDisposable

<PageTitle>Cookie Clicker — Blazor Fan Remake (unofficial)</PageTitle>

<!-- Full-width masthead: the news headline spans all columns, out of the
     cookie's focal path. Stands in for the original's center-top headline,
     which we can't reuse because our center column is the shop, not the
     (unimplemented) building visualization. The options gear sits at the far
     right — away from the cookie's click zone and the gameplay column, where
     players expect settings to live. -->
<UpdateBanner />
<div class="game-masthead">
    <NewsTicker @ref="_news" State="Save.State" />
    <OptionsMenu OnStateChanged="OnStateReplaced" />
</div>

<div class="game-shell">
    <!-- Left column: Big cookie + stats -->
    <section class="game-left">
        <StatsPanel State="Save.State" />
        <div class="cookie-area">
            <MilkLayer State="Save.State" />
            <CursorRing State="Save.State" />
            <BigCookie OnClick="OnClickCookie" />
            @foreach (var f in _floaters)
            {
                <span class="floater" style="left: @(f.X)px; top: @(f.Y)px;">
                    +@NumberFormat.Format(f.Amount)
                </span>
            }
            @foreach (var p in _crumbs)
            {
                <span class="crumb" style="@(p.Style())">@p.Glyph</span>
            }
        </div>
        <div class="game-footer">
            @* Credits sit inline with the title so the footer stays two rows —
               same vertical footprint as before we added credit links. Icons
               only: the "unofficial" disclaimer already sits in the subtitle
               below, so we don't repeat license/attribution text here (and
               spelling out "MIT Licensed" in a footer would misleadingly
               imply the license covers the game design, which it does not —
               see NOTICE.md). SVG paths are Font Awesome Free brand marks
               (CC BY 4.0); see NOTICE.md for attribution. *@
            <div class="game-title">
                <span>@Loc["ui.footer.title"]</span>
                <a class="game-link"
                   href="https://github.com/cholf5/blazor-clicker"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="@Loc["ui.footer.github"]"
                   title="@Loc["ui.footer.github"]">
                    <svg viewBox="0 0 496 512" aria-hidden="true">
                        <path d="M165.9 397.4c0 2-2.3 3.6-5.2 3.6-3.3 .3-5.6-1.3-5.6-3.6 0-2 2.3-3.6 5.2-3.6 3-.3 5.6 1.3 5.6 3.6zm-31.1-4.5c-.7 2 1.3 4.3 4.3 4.9 2.6 1 5.6 0 6.2-2s-1.3-4.3-4.3-5.2c-2.6-.7-5.5 .3-6.2 2.3zm44.2-1.7c-2.9 .7-4.9 2.6-4.6 4.9 .3 2 2.9 3.3 5.9 2.6 2.9-.7 4.9-2.6 4.6-4.6-.3-1.9-3-3.2-5.9-2.9zM244.8 8C106.1 8 0 113.3 0 252c0 110.9 69.8 205.8 169.5 239.2 12.8 2.3 17.3-5.6 17.3-12.1 0-6.2-.3-40.4-.3-61.4 0 0-70 15-84.7-29.8 0 0-11.4-29.1-27.8-36.6 0 0-22.9-15.7 1.6-15.4 0 0 24.9 2 38.6 25.8 21.9 38.6 58.6 27.5 72.9 20.9 2.3-16 8.8-27.1 16-33.7-55.9-6.2-112.3-14.3-112.3-110.5 0-27.5 7.6-41.3 23.6-58.9-2.6-6.5-11.1-33.3 2.6-67.9 20.9-6.5 69 27 69 27 20-5.6 41.5-8.5 62.8-8.5s42.8 2.9 62.8 8.5c0 0 48.1-33.6 69-27 13.7 34.7 5.2 61.4 2.6 67.9 16 17.7 25.8 31.5 25.8 58.9 0 96.5-58.9 104.2-114.8 110.5 9.2 7.9 17 22.9 17 46.4 0 33.7-.3 75.4-.3 83.6 0 6.5 4.6 14.4 17.3 12.1C428.2 457.8 496 362.9 496 252 496 113.3 383.5 8 244.8 8zM97.2 352.9c-1.3 1-1 3.3 .7 5.2 1.6 1.6 3.9 2.3 5.2 1 1.3-1 1-3.3-.7-5.2-1.6-1.6-3.9-2.3-5.2-1zm-10.8-8.1c-.7 1.3 .3 2.9 2.3 3.9 1.6 1 3.6 .7 4.3-.7 .7-1.3-.3-2.9-2.3-3.9-2-.6-3.6-.3-4.3 .7zm32.4 35.6c-1.6 1.3-1 4.3 1.3 6.2 2.3 2.3 5.2 2.6 6.5 1 1.3-1.3 .7-4.3-1.3-6.2-2.2-2.3-5.2-2.6-6.5-1zm-11.4-14.7c-1.6 1-1.6 3.6 0 5.9 1.6 2.3 4.3 3.3 5.6 2.3 1.6-1.3 1.6-3.9 0-6.2-1.4-2.3-4-3.3-5.6-2z" />
                    </svg>
                </a>
                <a class="game-link"
                   href="https://x.com/cholf5"
                   target="_blank"
                   rel="noopener noreferrer"
                   aria-label="@Loc["ui.footer.x"]"
                   title="@Loc["ui.footer.x"]">
                    <svg viewBox="0 0 512 512" aria-hidden="true">
                        <path d="M389.2 48h70.6L305.6 224.2 487 464H345L233.7 318.6 86.8 464H16.1L181.6 275.5 8 48H153.6L254.2 180.9 389.2 48zM364.4 421.8h39.1L151.1 88H109.1L364.4 421.8z" />
                    </svg>
                </a>
            </div>
            <div class="game-subtitle">@Loc["ui.footer.subtitle"]</div>
        </div>
    </section>

    <!-- Center column: Buildings shop -->
    <section class="game-center">
        <BuildingList State="Save.State" OnPurchased="OnPurchased" />
    </section>

    <!-- Right column: Upgrades + achievements + sugar lumps + ascend + save controls -->
    <aside class="game-right">
        <UpgradeStore State="Save.State" OnPurchased="OnPurchased" />
        <SugarLumpWidget State="Save.State" />
        <AscendPanel State="Save.State" OnAscended="OnAscended" />
        <AchievementList State="Save.State" />
    </aside>
</div>

<GoldenCookieLayer State="Save.State" OnClicked="OnGoldenClicked" />
<AchievementToasts @ref="_toasts" State="Save.State" OnUnlocked="OnAchievementUnlocked" />

<OfflineDialog Summary="_offlineSummary" OnDismiss="DismissOffline" />

@code {
    private AchievementToasts? _toasts;
    private NewsTicker? _news;
    private readonly List<Floater> _floaters = new();
    private readonly List<Crumb> _crumbs = new();
    private readonly Random _fx = new();
    private OfflineEarningsSummary? _offlineSummary;

    protected override async Task OnInitializedAsync()
    {
        Loop.OnTick += OnTick;
        Save.OnStateReplaced += OnStateReplacedInternal;
        Loc.OnLanguageChanged += OnLanguageChanged;

        await Audio.InitAsync();
        await Save.LoadAsync();

        // Apply the effective language now the save (and its ChosenLanguage) is
        // loaded: the persisted choice wins, otherwise auto-detect the browser.
        await Lang.InitAsync();

        _offlineSummary = Save.PendingOfflineSummary;
        if (_offlineSummary is not null) Save.AcknowledgeOfflineSummary();

        Loop.Start();

        // Begin polling for new deployments so long-lived idle sessions can be
        // offered a refresh. Fire-and-forget: failures inside are swallowed and
        // simply mean "no update prompt", which must never block startup.
        _ = Updater.StartAsync();
    }

    private void OnTick()
    {
        _toasts?.Pump();
        _news?.Pump();
        // Age out floaters + crumbs — CSS drives the animation, we just cap counts.
        var now = DateTime.UtcNow;
        _floaters.RemoveAll(f => (now - f.CreatedAt).TotalMilliseconds > 900);
        _crumbs.RemoveAll(c => (now - c.CreatedAt).TotalMilliseconds > 900);
        InvokeAsync(StateHasChanged);
    }

    private async Task OnClickCookie(MouseEventArgs e)
    {
        var gained = Save.State.Click();
        Audio.PlayClick();

        _floaters.Add(new Floater(
            (int)e.ClientX + _fx.Next(-15, 16),
            (int)e.ClientY - 20,
            gained,
            DateTime.UtcNow));
        if (_floaters.Count > 30) _floaters.RemoveAt(0);

        // Spawn 3-5 crumb particles that fly outward from the click point.
        var crumbCount = 3 + _fx.Next(3);
        for (var i = 0; i < crumbCount; i++)
        {
            _crumbs.Add(new Crumb(
                (int)e.ClientX,
                (int)e.ClientY,
                _fx.Next(-140, 141),
                -60 - _fx.Next(80),
                _fx.Next(-180, 181),
                _fx.Next(3) switch { 0 => "🍪", 1 => "🥠", _ => "🍫" },
                DateTime.UtcNow));
        }
        if (_crumbs.Count > 60) _crumbs.RemoveRange(0, _crumbs.Count - 60);

        await Task.CompletedTask;
    }

    private void OnPurchased() => Audio.PlayPurchase();

    private void OnGoldenClicked()
    {
        Audio.PlayGolden();
    }

    private void OnAchievementUnlocked() => Audio.PlayAchievement();

    private async Task OnAscended()
    {
        // Force an immediate save after ascension so we don't lose the reset
        // if the tab dies before the next autosave interval.
        try { await Save.SaveNowAsync(); } catch { }
        StateHasChanged();
    }

    private void DismissOffline()
    {
        _offlineSummary = null;
        StateHasChanged();
    }

    private void OnStateReplacedInternal() => InvokeAsync(async () =>
    {
        // Import / wipe swapped in a different GameState — re-derive the language
        // from its ChosenLanguage (or re-detect the system language when null) so
        // the display and the picker stay in sync with the new save.
        await Lang.InitAsync();
        StateHasChanged();
    });
    private void OnStateReplaced() => StateHasChanged();
    private void OnLanguageChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Loop.OnTick -= OnTick;
        Save.OnStateReplaced -= OnStateReplacedInternal;
        Loc.OnLanguageChanged -= OnLanguageChanged;
        Loop.Stop();
    }

    private sealed record Floater(int X, int Y, double Amount, DateTime CreatedAt);

    private sealed record Crumb(int X, int Y, int Dx, int Dy, int Rot, string Glyph, DateTime CreatedAt)
    {
        // Inline style feeds the crumb-fly CSS keyframe with per-particle vectors.
        public string Style() =>
            $"left: {X}px; top: {Y}px; --dx: {Dx}px; --dy: {Dy}px; --rot: {Rot}deg;";
    }
}
