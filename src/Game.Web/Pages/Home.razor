@page "/"
@inject SaveCoordinator Save
@inject GameLoop Loop
@implements IDisposable

<PageTitle>Cookie Clicker — Blazor Fan Remake (unofficial)</PageTitle>

<div class="game-shell">
    <!-- Left column: Big cookie + stats -->
    <section class="game-left">
        <StatsPanel State="Save.State" />
        <div class="cookie-area">
            <BigCookie OnClick="OnClickCookie" />
            @foreach (var f in _floaters)
            {
                <span class="floater" style="left: @(f.X)px; top: @(f.Y)px;">
                    +@NumberFormat.Format(f.Amount)
                </span>
            }
        </div>
        <div class="game-footer">
            <div class="game-title">Cookie Clicker · Blazor fan remake</div>
            <div class="game-subtitle">Unofficial. Not affiliated with Orteil / DashNet. Autosaves every 15s to your browser's local storage.</div>
        </div>
    </section>

    <!-- Center column: Buildings shop -->
    <section class="game-center">
        <BuildingList State="Save.State" />
    </section>

    <!-- Right column: Upgrades + achievements + save controls -->
    <aside class="game-right">
        <UpgradeStore State="Save.State" />
        <AchievementList State="Save.State" />
        <SaveMenu OnStateChanged="OnStateReplaced" />
    </aside>
</div>

<GoldenCookieLayer State="Save.State" />
<AchievementToasts @ref="_toasts" State="Save.State" />

@code {
    private AchievementToasts? _toasts;
    private readonly List<Floater> _floaters = new();
    private readonly Random _floaterRandom = new();

    protected override async Task OnInitializedAsync()
    {
        Loop.OnTick += OnTick;
        Save.OnStateReplaced += OnStateReplacedInternal;

        await Save.LoadAsync();
        Loop.Start();
    }

    private void OnTick()
    {
        _toasts?.Pump();
        // Age out floaters (they self-animate via CSS but we cap the list).
        _floaters.RemoveAll(f => (DateTime.UtcNow - f.CreatedAt).TotalMilliseconds > 900);
        InvokeAsync(StateHasChanged);
    }

    private async Task OnClickCookie(MouseEventArgs e)
    {
        var gained = Save.State.Click();
        _floaters.Add(new Floater(
            (int)e.ClientX + _floaterRandom.Next(-15, 16),
            (int)e.ClientY - 20,
            gained,
            DateTime.UtcNow));
        if (_floaters.Count > 30) _floaters.RemoveAt(0);
        await Task.CompletedTask;
    }

    private void OnStateReplacedInternal() => InvokeAsync(StateHasChanged);
    private void OnStateReplaced() => StateHasChanged();

    public void Dispose()
    {
        Loop.OnTick -= OnTick;
        Save.OnStateReplaced -= OnStateReplacedInternal;
        Loop.Stop();
    }

    private sealed record Floater(int X, int Y, double Amount, DateTime CreatedAt);
}
